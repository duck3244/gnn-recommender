{
  "name": "gnn-recommender",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": "18.x",
    "npm": ">=9"
  },
  "packageManager": "npm@10.8.2",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "cd backend && uvicorn api.main:app --host 127.0.0.1 --port 8000 --reload",
    "dev:web": "npm --prefix frontend run dev",
    "build:web": "npm --prefix frontend run build",
    "typegen": "npm --prefix frontend run typegen",
    "serve": "cd backend && uvicorn api.main:app --host 127.0.0.1 --port 8000"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
